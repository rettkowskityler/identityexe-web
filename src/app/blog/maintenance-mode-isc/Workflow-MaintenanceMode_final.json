          "method": "post",
          "oAuthClientId": "ENTERCLIENTID",
          "oAuthClientSecret": null,
          "oAuthCredentialLocation": "oAuthInHeader",
          "oAuthTokenUrl": "https://TENANT.api.identitynow.com/oauth/token",
          "requestContentType": "json",
          "url": "https://TENANT.api.identitynow.com/v2024/sources/{{$.interactiveForm.formData.sources}}/schedules"
        },
        "catch": [
          {
            "next": "Interactive Message"
          }
        ],
        "displayName": "Update Account Aggregation Schedule",
        "nextStep": "Interactive Message",
        "type": "action",
        "versionNumber": 2
