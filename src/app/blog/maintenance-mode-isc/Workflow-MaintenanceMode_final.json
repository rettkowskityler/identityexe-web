      "HTTP Request 6": {
        "actionId": "sp:http",
        "attributes": {
          "authenticationType": "OAuth",
          "jsonPatchRequestBody": [
            {
              "op": "add",
              "path": "/connectorAttributes/enableProvisioningFeature",
              "value": false
            },
            {
              "op": "add",
              "path": "/connectorAttributes/disable_health_check",
              "value": true
            },
            {
              "op": "replace",
              "path": "/features",
              "value": []
            },
            {
              "op": "add",
              "path": "/connectorAttributes/groupaggregationschedule",
              "value": "{{$.hTTPRequest1.body.cronExpression}}"
            },
            {
              "op": "add",
              "path": "/connectorAttributes/accountaggregationschedule",
              "value": "{{$.hTTPRequest2.body.cronExpression}}"
            },
            {
              "op": "add",
              "path": "/connectorAttributes/maintenancemode",
              "value": true
            }
          ],
          "method": "patch",
          "oAuthClientId": "ENTERCLIENTID",
          "oAuthClientSecret": null,
          "oAuthCredentialLocation": "oAuthInHeader",
          "oAuthTokenUrl": "https://TENANT.api.identitynow.com/oauth/token",
          "requestContentType": "json-patch+json",
          "url": "https://TENANT.api.identitynow.com/v2024/sources/{{$.interactiveForm.formData.sources}}"
        },
        "catch": [
          {
            "next": "End Step - Failure"
          }
