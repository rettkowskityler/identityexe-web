        "type": "action",
        "versionNumber": 2
      },
      "HTTP Request 2": {
        "actionId": "sp:http",
        "attributes": {
          "authenticationType": "OAuth",
          "method": "get",
          "oAuthClientId": "ENTERCLIENTID",
          "oAuthClientSecret": null,
          "oAuthCredentialLocation": "oAuthInHeader",
          "oAuthTokenUrl": "https://TENANT.api.identitynow.com/oauth/token",
          "requestContentType": null,
          "url": "https://TENANT.api.identitynow.com/v2024/sources/{{$.interactiveForm.formData.sources}}/schedules/ACCOUNT_AGGREGATION"
