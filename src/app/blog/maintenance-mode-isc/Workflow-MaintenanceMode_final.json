          "oAuthClientSecret": null,
          "oAuthCredentialLocation": "oAuthInHeader",
          "oAuthScope": null,
          "oAuthTokenUrl": "https://TENANT.api.identitynow.com/oauth/token",
          "requestContentType": null,
