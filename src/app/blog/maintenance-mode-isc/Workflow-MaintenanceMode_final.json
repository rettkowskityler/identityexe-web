          "method": "patch",
          "oAuthClientId": "ENTERCLIENTID",
          "oAuthClientSecret": null,
          "oAuthCredentialLocation": "oAuthInHeader",
          "oAuthTokenUrl": "https://TENANT.api.identitynow.com/oauth/token",
          "requestContentType": "json-patch+json",
          "url": "https://TENANT.api.identitynow.com/v2024/sources/{{$.interactiveForm.formData.sources}}"
