        "displayName": "Patch Changes to Source",
        "nextStep": "HTTP Request 8",
        "type": "action",
        "versionNumber": 2
      },
      "HTTP Request 8": {
        "actionId": "sp:http",
        "attributes": {
          "authenticationType": "OAuth",
          "jsonRequestBody": {
            "cronExpression": "{{$.hTTPRequest3.body.connectorAttributes.groupaggregationschedule}}",
