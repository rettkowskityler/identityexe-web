    "steps": {
      "Compare Strings": {
        "actionId": "sp:compare-strings",
        "choiceList": [
          {
            "comparator": "StringEquals",
            "nextStep": "HTTP Request 7",
            "variableA.$": "$.interactiveForm.formData.enableOrDisableMaintenanceMode",
            "variableB": "Disable"
          }
        ],
        "defaultStep": "HTTP Request 1",
        "displayName": "Check if Enabled or Disabled",
        "type": "choice"
      },
      "End Step - Failure": {
        "actionId": "sp:operator-failure",
        "displayName": "",
        "failureName": "api call failed",
        "type": "failure"
      },
      "End Step - Success": {
        "actionId": "sp:operator-success",
        "displayName": "",
        "type": "success"
      },
      "Get Identity": {
        "actionId": "sp:get-identity",
        "attributes": {
          "id.$": "$.trigger.launchedBy.id"
