        "displayName": "",
        "nextStep": "Send Email",
        "type": "action",
        "versionNumber": 1
      },
      "Send Email": {
        "actionId": "sp:send-email",
        "attributes": {
          "body": "<p>The maintenance mode workflow for <strong>{{$.hTTPRequest3.body.name}}</strong> has been completed successfully.</p>\n<p><strong>Execution Details:</strong></p>\n<p><strong>Action:</strong> Maintenance Mode has been {{$.interactiveForm.formData.enableOrDisableMaintenanceMode}} for this source.</p>\n<p><strong>Reason:</strong> {{$.interactiveForm.formData.enterReason}}</p>\n<p><strong>Account Aggregation Schedule:</strong> {{$.hTTPRequest3.body.connectorAttributes.accountaggregationschedule}}</p>\n<p><strong>Group Aggregation Schedule:</strong> {{$.hTTPRequest3.body.connectorAttributes.groupaggregationschedule}}</p>\n<p>All configuration changes have been applied to the source, and the connection state is now updated as requested.</p>",
          "context": {},
          "recipientEmailList": [
            "NOTIFICATIONEMAIL!"
          ],
          "subject": "Maintenance Mode Update: {{$.hTTPRequest3.body.name}} ({{$.interactiveForm.formData.enableOrDisableMaintenanceMode}})"
        },
        "displayName": "",
        "nextStep": "End Step - Success",
        "type": "action",
        "versionNumber": 2
